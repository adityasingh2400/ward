# WARD environment — copy to .env and fill in.
# Tonight-critical:
ANTHROPIC_API_KEY=            # console.anthropic.com — vision detection + all agents
CLICKHOUSE_HOST=              # https://<id>.<region>.clickhouse.cloud:8443 (Connect dialog)
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# 3D twins (account: marble.worldlabs.ai — free tier = 4 world generations TOTAL):
WORLDLABS_API_KEY=

# Wire-up (optional; system runs without them — see TOMORROW.md):
THESYS_API_KEY=               # console.thesys.dev — hosted C1 path (OSS OpenUI path needs no key)
LANGFUSE_PUBLIC_KEY=          # cloud.langfuse.com — swap target for the trace.ts JSONL shim
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
FIVEONEONE_API_KEY=           # 511.org/open-data/token — optional incident metadata

# Tuning:
# DETECT_MODEL=claude-fable-5   # per-frame vision model (the cost lever)
# AGENT_MODEL=claude-fable-5    # investigator/composer/standing-query model
# VENUE_CAM=on                  # macOS webcam as "venue cam" (ffmpeg avfoundation)
