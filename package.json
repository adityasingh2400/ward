{
  "name": "ward",
  "version": "0.1.0",
  "private": true,
  "description": "WARD — AI civic intelligence portal. Agents watch city cameras, log observations to ClickHouse, and generate dashboards for policymakers via OpenUI.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "migrate": "tsx server/migrate.ts",
    "sampler": "tsx server/sampler.ts",
    "watcher": "tsx server/watcher.ts",
    "venuecam": "tsx server/venuecam.ts",
    "golden": "tsx test/golden.ts",
    "soak": "tsx test/soak.ts",
    "all": "concurrently -n sampler,watcher,web -c blue,yellow,green \"npm run sampler\" \"npm run watcher\" \"npm run dev\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@clickhouse/client": "^1.20.0",
    "@openuidev/react-headless": "^0.8.2",
    "@openuidev/react-lang": "^0.2.6",
    "@openuidev/react-ui": "^0.11.8",
    "@sparkjsdev/spark": "^2.1.0",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "leaflet": "^1.9.4",
    "nanoid": "^5.0.9",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.0",
    "three": "^0.182.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.182.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
